# ── X Layer Network ──
XLAYER_RPC=https://rpc.xlayer.tech
XLAYER_TESTNET_RPC=https://testrpc.xlayer.tech
XLAYER_CHAIN_ID=196

# ── Agent Wallets ──
# Generate 5 separate wallets (e.g., via ethers.Wallet.createRandom())
# Fund each with small amount of USDC on X Layer
SCOUT_PK=0x...
ANALYST_PK=0x...
EXECUTOR_PK=0x...
TREASURY_PK=0x...
DEPLOYER_PK=0x...

# ── OnchainOS API ──
# Get from https://web3.okx.com/build/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# ── Smart Contract ──
REGISTRY_ADDRESS=

# ── Tokens on X Layer ──
# Verify these on X Layer explorer before using
USDC_ADDRESS=
USDT_ADDRESS=

# ── Agent Configuration ──
SCOUT_PORT=3001
ANALYST_PORT=3002
EXECUTOR_PORT=3003
TREASURY_PORT=3004
ORCHESTRATOR_WS_PORT=3005
DASHBOARD_PORT=3000

# ── CEX Trading (OKX) ──
# Enable to execute real CEX orders (default: simulated)
CEX_TRADING_ENABLED=false
OKX_TRADE_API_KEY=
OKX_TRADE_SECRET_KEY=
OKX_TRADE_PASSPHRASE=

# ── Mode ──
DEMO_MODE=false                   # true = simulated $800K portfolio with real prices
DEMO_TRADE_SIZE=10000            # trade size per execution in demo mode ($10K)
FEE_TIER=professional            # retail | professional | vip

# ── x402 Payments ──
X402_REAL_PAYMENTS=false               # true = real USDC transfers on X Layer
X402_MAX_PAYMENT=0.10                  # max USDC per single payment

# ── Telegram Bot ──
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=                    # Get from @BotFather
TELEGRAM_CHAT_ID=                      # Your chat/group ID
ALERT_SPREAD_THRESHOLD=0.4            # Alert when spread > 0.4%
TELEGRAM_THROTTLE_MONITOR=10          # Send every Nth monitor cycle

# ── Wallet Provider ──
# 'ethers' (default, raw private keys) or 'agentic' (OKX TEE-secured)
WALLET_PROVIDER=ethers

# Agentic Wallet (only needed when WALLET_PROVIDER=agentic)
# Get token by logging into Agentic Wallet via email
AGENTIC_WALLET_TOKEN=

# ── Strategy Parameters ──
SPREAD_THRESHOLD=0.003
MAX_TRADE_SIZE_USDC=500
DAILY_LOSS_LIMIT_PCT=0.05
SCOUT_POLL_INTERVAL=5000
PORTFOLIO_POLL_INTERVAL=30000
